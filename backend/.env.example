NODE_ENV=development
PORT=5000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shms
DB_USER=postgres
DB_PASSWORD=postgres
JWT_SECRET=your-jwt-secret-key-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost
# Set to false only if using self-signed certs (not recommended for production)
# DB_SSL_REJECT_UNAUTHORIZED=true
# Auto-provision patient login (disabled by default; set true only for local dev with seed data)
# AUTO_PROVISION_PATIENT_LOGIN=false
# Optional for local development only. Prefer IAM role in AWS runtime.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=your-s3-bucket-name
GROQ_API_KEY=your-groq-api-key
